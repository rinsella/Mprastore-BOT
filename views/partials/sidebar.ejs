<aside class="sidebar">
  <div class="brand">
    <span class="brand-logo">M</span>
    <span class="brand-text">Mprastore<br /><small>BOT Admin</small></span>
  </div>
  <nav class="nav">
    <a class="nav-item <%= active === 'dashboard' ? 'active' : '' %>" href="<%= base %>">
      <span>📊</span> Dashboard
    </a>
    <a class="nav-item <%= active === 'orders' ? 'active' : '' %>" href="<%= base %>/orders">
      <span>📦</span> Orders
    </a>
    <a class="nav-item" href="<%= base %>/orders?status=WAITING_ADMIN">
      <span>⏳</span> Pending
    </a>
    <a class="nav-item" href="<%= base %>/orders?status=CONNECTED">
      <span>✅</span> Connected
    </a>
    <a class="nav-item" href="<%= base %>/orders?status=FAILED_LOOKUP">
      <span>⚠️</span> Failed Lookup
    </a>
    <a class="nav-item <%= active === 'lookup' ? 'active' : '' %>" href="<%= base %>/lookup">
      <span>🔍</span> Manual Lookup
    </a>
  </nav>
  <form class="nav-logout" method="POST" action="<%= base %>/logout">
    <input type="hidden" name="_csrf" value="<%= csrfToken %>" />
    <button type="submit" class="btn-logout"><span>🚪</span> Logout</button>
  </form>
</aside>
