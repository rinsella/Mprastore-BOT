<header class="topbar">
  <button id="sidebarToggle" class="hamburger" aria-label="Menu">☰</button>
  <h1 class="topbar-title"><%= typeof title !== 'undefined' ? title : 'Admin' %></h1>
  <div class="topbar-right">
    <span class="health-badge" title="Status server">● Online</span>
    <% if (typeof currentUser !== 'undefined' && currentUser) { %>
      <span class="topbar-user">👤 <%= currentUser %></span>
    <% } %>
  </div>
</header>
