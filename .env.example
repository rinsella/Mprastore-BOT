BOT_TOKEN=your_telegram_bot_token
ADMIN_IDS=123456789
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/domainbot
CHECK_INTERVAL_MINUTES=10
NODE_ENV=production
PORT=3000

# ===== Web Admin Panel =====
# URL publik aplikasi (dipakai untuk link panel web di bot). Tanpa trailing slash.
WEB_PUBLIC_URL=https://your-domain.com
# Aktifkan/nonaktifkan panel web admin. Jika false hanya /health yang publik.
ADMIN_WEB_ENABLED=true
# Path dasar panel admin (bisa diganti, mis. /panel-mprastore).
ADMIN_WEB_PATH=/admin
# Username login web admin.
ADMIN_WEB_USERNAME=admin
# Disarankan: hash bcrypt dari password. Buat dengan:
#   node -e "console.log(require('bcryptjs').hashSync('passwordku',10))"
ADMIN_WEB_PASSWORD_HASH=
# Alternatif (kurang aman): password teks biasa. Hanya dipakai jika HASH kosong.
ADMIN_WEB_PASSWORD=change_me
# Secret untuk menandatangani session cookie. WAJIB diisi acak & rahasia di produksi.
SESSION_SECRET=change_this_to_random_secret
# Masa berlaku sesi login (jam).
SESSION_MAX_AGE_HOURS=8
